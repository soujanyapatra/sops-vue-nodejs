{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/news/trending",
      "dest": "/api/news/trending.ts"
    },
    {
      "src": "/api/news/search",
      "dest": "/api/news/search.ts"
    },
    {
      "src": "/api/news",
      "dest": "/api/news.ts"
    },
    {
      "src": "/api/secret-status",
      "dest": "/api/secret-status.ts"
    },
    {
      "src": "/api/categories",
      "dest": "/api/categories.ts"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
